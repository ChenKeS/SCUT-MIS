.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 0;
}

.header {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 15rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  display: block;
}

.role-section {
  background: white;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 0 30rpx 40rpx 30rpx;
}

.section-title {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
  text-align: center;
  font-weight: bold;
}

.role-buttons {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.role-btn {
  width: 180rpx;
  font-size: 30rpx;
  background: #f5f5f5;
  color: #333;
  border-radius: 50rpx;
  line-height: 2;
  padding: 12rpx 0;
  margin: 0;
  text-align: center;
  font-weight: 500;
}

.role-btn.active {
  background: #667eea;
  color: white;
}

.role-tip {
  text-align: center;
  font-size: 26rpx;
  color: #666;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

/* 四个功能模块 - 满宽 */
.menu-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 0 20rpx;
}

.menu-item {
  width: calc(50% - 15rpx);
  background: white;
  border-radius: 28rpx;
  padding: 50rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s;
  margin-bottom: 30rpx;
  box-sizing: border-box;
}

.menu-item:active {
  transform: scale(0.98);
  background: #f8f8f8;
}

.menu-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 20rpx;
}

.menu-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.menu-desc {
  font-size: 22rpx;
  color: #999;
  display: block;
}