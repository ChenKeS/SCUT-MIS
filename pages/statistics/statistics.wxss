page {
  background: #f5f5f5;
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #f5f5f5;
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #667eea;
  color: white;
  padding: 25rpx 30rpx;
  flex-shrink: 0;
}

.header text {
  font-size: 36rpx;
  font-weight: bold;
}

.refresh-btn {
  background: rgba(255,255,255,0.2);
  color: white;
  font-size: 28rpx;
  padding: 10rpx 30rpx;
  border-radius: 50rpx;
  margin: 0;
}

.stat-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
  box-sizing: border-box;
}

.stat-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.stat-card:last-child {
  margin-bottom: 0;
}

.stat-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #eee;
}

.stat-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.stat-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.stat-picker {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  color: #666;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  font-size: 24rpx;
  color: #999;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  text-align: center;
  padding: 20rpx 0;
}

.stat-unit {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  background: white;
  padding: 40rpx 60rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #667eea;
}