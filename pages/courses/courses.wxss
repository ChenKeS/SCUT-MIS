.container {
  padding: 20rpx 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #667eea;
  color: white;
  padding: 25rpx 30rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.header text {
  font-size: 36rpx;
  font-weight: bold;
}

.add-btn {
  background: rgba(255,255,255,0.2);
  color: white;
  font-size: 28rpx;
  padding: 10rpx 30rpx;
  border-radius: 50rpx;
  margin: 0;
}

.search-bar {
  background: white;
  padding: 20rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.search-bar input {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
}

.course-card {
  background: white;
  border-radius: 20rpx;
  padding: 25rpx 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.course-info {
  flex: 1;
}

.course-id {
  font-size: 26rpx;
  color: #667eea;
  display: block;
  margin-bottom: 8rpx;
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.course-detail {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 4rpx;
}

.course-teacher, .course-canceled {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.course-actions {
  display: flex;
  gap: 15rpx;
}

.edit-btn, .delete-btn {
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 50rpx;
  margin: 0;
}

.edit-btn {
  background: #e6f7ff;
  color: #1890ff;
}

.delete-btn {
  background: #fff1f0;
  color: #ff4d4f;
}

.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 24rpx;
  width: 80%;
  max-height: 80%;
  padding: 40rpx;
  overflow-y: auto;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  display: block;
  margin-bottom: 30rpx;
}

.modal-content input {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-buttons button {
  flex: 1;
  border-radius: 50rpx;
  font-size: 28rpx;
}