page {
  background: #f5f5f5;
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  background: #f5f5f5;
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #667eea;
  color: white;
  padding: 25rpx 30rpx;
  flex-shrink: 0;
}

.header text {
  font-size: 36rpx;
  font-weight: bold;
}

.add-btn {
  background: rgba(255,255,255,0.2);
  color: white;
  font-size: 28rpx;
  padding: 10rpx 30rpx;
  border-radius: 50rpx;
  margin: 0;
}

.search-bar {
  background: white;
  padding: 20rpx;
  flex-shrink: 0;
  border-bottom: 1rpx solid #eee;
}

.search-bar input {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  line-height: 1.4;
  text-align: center;
  height: 80rpx;
}

.course-list {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx;
  box-sizing: border-box;
}

.course-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.course-card:last-child {
  margin-bottom: 0;
}

.course-info {
  flex: 1;
}

.course-id {
  font-size: 26rpx;
  color: #667eea;
  display: block;
  margin-bottom: 8rpx;
}

.course-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.course-detail {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 4rpx;
}

.course-teacher, .course-canceled {
  font-size: 22rpx;
  color: #999;
  display: block;
}

/* 按钮样式 - 垂直排列 */
.course-actions {
  display: flex;
  flex-direction: column;  /* 垂直排列 */
  gap: 10rpx;              /* 按钮间距 */
  flex-shrink: 0;
}

.edit-btn, .delete-btn {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
  margin: 0;
  min-width: 60rpx;
  text-align: center;
}

.edit-btn {
  background: #e6f7ff;
  color: #1890ff;
}

.delete-btn {
  background: #fff1f0;
  color: #ff4d4f;
}

.empty-tip {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 24rpx;
  width: 85%;
  max-height: 85%;
  padding: 40rpx;
  overflow-y: auto;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  display: block;
  margin-bottom: 30rpx;
  color: #333;
}

.modal-content input {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;     /* 增加上下内边距 */
  margin-bottom: 20rpx;
  font-size: 30rpx;          /* 增大字体 */
  width: 100%;
  box-sizing: border-box;
  background: #fafafa;
  height: 80rpx;             /* 固定高度 */
  line-height: 1.4;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-buttons button {
  flex: 1;
  border-radius: 50rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  background: #f5f5f5;
  color: #333;
}

.modal-buttons button:first-child {
  background: #667eea;
  color: white;
}